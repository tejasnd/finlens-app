# FinLens backend configuration. Copy to `.env` and adjust.
# Everything runs locally; cloud keys are optional fallbacks only.

# ── LLM routing ────────────────────────────────────────────────────────────
# Which provider to try first, and which to fall back to if it fails.
# Providers: "ollama" (local), "claude", "openai"
LLM_PRIMARY=ollama
LLM_FALLBACK=claude        # set blank to disable cloud fallback
REQUEST_TIMEOUT=60

# ── Ollama (local, default) ────────────────────────────────────────────────
# Install: https://ollama.com  →  `ollama pull llama3.2:3b`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Cloud providers (optional) ─────────────────────────────────────────────
# Used as a fallback, or when the app's AI picker selects this provider. Set the
# MODEL to the current model id you have access to — no version is hardcoded in
# the source, so you choose it here. Leave blank to stay fully offline (Ollama).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=            # e.g. claude-haiku-4-5 | claude-sonnet-4-6 | claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=              # e.g. gpt-4o-mini | gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=              # e.g. gemini-2.0-flash | gemini-2.0-flash-lite

# Note: the app's AI-categorization picker sends the provider + your key per
# request; the model is resolved from the matching *_MODEL above.

# ── CORS ───────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
